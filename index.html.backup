        // Dialogue system state
        let dialogueState = {
            lastDialogueTime: 0,
            dialogueInterval: 10 * 60 * 1000, // 10 minutes
            bubble: null,
            currentLevel: 1
        };

        // REMOVED: Old speech bubble system - replaced with tooltip
